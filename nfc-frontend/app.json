{
  "expo": {
    "name": "NFC Bus App",
    "slug": "nfc-bus-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F4C81"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Allow BusPay Nepal to scan NFC cards for fare payment."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NFCReaderUsageDescription": "Allow BusPay Nepal to scan NFC cards for fare payment."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "NDEF"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F4C81"
      },
      "permissions": [
        "android.permission.NFC"
      ],
      "package": "androidcom.nipun.buspaynepal"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
